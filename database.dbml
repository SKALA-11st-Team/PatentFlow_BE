// PatentFlow_BE Database Schema - 2026-05-29
//
// Runtime database
//   PostgreSQL database: patentflow
//   Default schema: patentflow
//   JDBC URL default: jdbc:postgresql://localhost:5432/patentflow?currentSchema=patentflow
//   Init SQL: docker/postgres/init/01-create-patentflow-schema.sql
//     - CREATE SCHEMA IF NOT EXISTS patentflow
//     - CREATE EXTENSION IF NOT EXISTS vector WITH SCHEMA public
//     - SET search_path TO patentflow, public
//
// Spring Boot JPA
//   spring.jpa.hibernate.ddl-auto=update
//   hibernate.default_schema=patentflow
//   hibernate.hbm2ddl.create_namespaces=true
//
// JPA-managed tables
//   patents, patent_review_history, quarter_settings, review_period_templates,
//   mailing_history, departments, users, auth_sessions, annual_fee_adjustments,
//   system_settings
//
// Shared pgvector table
//   industry_report_chunks is created by PatentFlow_Agent via psycopg.
//
// Relationship note
//   Most domain links are stored as scalar id columns in JPA. Refs below document
//   logical relationships used by the application; they are not all guaranteed
//   to be physical database FK constraints under ddl-auto=update.

Table patents {
  patent_id varchar(32) [pk, note: "PatentMetadataEntity.patentId; app id format: PAT-YYYY-NNNN"]
  management_number varchar(64) [not null, unique, note: "Internal management number, e.g. P202405001-KR0"]
  draft_title varchar(1000)
  title varchar(1000)
  business_area varchar(128) [note: "Business classification. Defaults are stored/served via system_settings classification.business."]
  technology_area varchar(256) [note: "Technology classification. Defaults are stored/served via system_settings classification.technology."]
  product_name varchar(512)
  country varchar(16) [note: "Supported annual-fee extension settings: KR, JP, CN, US, TW"]
  joint_application varchar(16) [note: "Y/N style source value"]
  co_applicant_name varchar(512)
  patent_status varchar(64) [note: "PatentLifecycleStatus enum: ACTIVE | ABANDONED | EXPIRED"]
  is_in_review boolean [not null, default: false, note: "Current review flag; true while any active review workflow is open"]
  application_date date
  registration_date date
  application_number varchar(64)
  registration_number varchar(64)
  expected_expiration_date date [note: "Legal expiration date"]
  fee_due_date date [note: "Current annual-fee due date; per-quarter snapshot is patent_review_history.annual_fee_due_date"]
  created_at timestamp [not null, note: "BaseEntity @CreatedDate, LocalDateTime"]
  updated_at timestamp [not null, note: "BaseEntity @LastModifiedDate, LocalDateTime"]
}

Table patent_review_history {
  id varchar(64) [pk, note: "{patent_id}|{quarter_key}"]
  patent_id varchar(32) [not null]
  quarter_key varchar(16) [not null]
  review_workflow_status varchar(64) [note: "ReviewWorkflowStatus enum: NOT_IN_REVIEW | REVIEW_QUARTER_STARTED | MAIL_READY | WAITING_BUSINESS_RESPONSE | BUSINESS_RESPONSE_RECEIVED"]
  ai_recommendation varchar(64) [note: "Recommendation enum: MAINTAIN | REVIEW_AGAIN | ABANDON | HOLD (AI 원본 — 법무 편집 미반영)"]
  ai_report_id varchar(128)
  ai_report_created_at timestamptz
  ai_recommendation_reason text [note: "LLM 생성 텍스트(요약 markdown) — varchar(2000) 오버플로 결함 수정"]
  ai_total_score int
  ai_average_score double [note: "0~100 평균(가중치 적용 시 가중 평균)"]
  ai_final_grade varchar(16)
  ai_final_indicator varchar(128)
  ai_degraded boolean [note: "부분/폴백 생성 여부"]
  ai_failure_reason text
  ai_scores_json text [note: "JSON text: evaluation scores by category"]
  ai_missing_information_json text [note: "JSON text: missing information list"]
  ai_key_evidence text [note: "리포트 레벨 핵심 근거 (ORCH-06/AIREPORT-02)"]
  ai_judgement_grounds_json text [note: "JSON text: 판단 근거 목록"]
  ai_business_check_requests_json text [note: "JSON text: 사업부 확인 요청 목록"]
  ai_external_sources_json text [note: "JSON text: [{title, url}]"]
  ai_report_markdown text [note: "Full AI report markdown cache"]
  ai_report_markdown_path varchar(1000) [note: "deprecated(AIREPORT-03/04) — 항상 null"]
  ai_edit_overrides_json text [note: "FR-LEGAL-09: 법무 편집 오버라이드(수정 필드만). null이면 원본 그대로"]
  ai_edited_by varchar(128)
  ai_edited_at timestamptz
  ai_edit_version int [note: "낙관적 락 토큰(동시 편집 409)"]
  ai_edit_base_report_id varchar(128) [note: "ai_report_id와 다르면 편집 이후 재생성됨(stale)"]
  ai_applied_criteria_json text [note: "이 레포트에 적용된 가치평가 기준(valuationConfig) 스냅샷"]
  summary_text text
  summary_problem_solved text
  summary_core_technical_points_json text [note: "JSON text: core technical point list"]
  summary_claims text
  summary_missing_fields_json text [note: "JSON text: missing field list"]
  business_opinion_decision varchar(64) [note: "BusinessOpinionDecision enum: MAINTAIN | ABANDON"]
  business_opinion_reason text
  business_opinion_submitted_by varchar(128)
  business_opinion_submitted_at timestamptz
  business_checklist_total int
  business_qualitative_score int
  business_checklist_scores_json text [note: "JSON text: [{itemId, score, memo}]"]
  business_ai_report_created_at timestamptz [note: "AI report timestamp snapshot at business submission time"]
  business_ai_report_snapshot_json text [note: "제출 시점에 사업부가 실제로 본 레포트 전체(JSON) — 편집/재생성 후 복원용"]
  business_ai_recommendation varchar(64) [note: "Recommendation snapshot at business submission time"]
  business_ai_total_score int [note: "AI score snapshot at business submission time (0~100 평균, CONTRACT-02)"]
  legal_action_result varchar(64) [note: "LegalActionResult enum: MAINTAINED | ABANDONED"]
  final_decision_id varchar(64)
  final_decision_reason text
  final_decision_decided_at timestamptz
  final_decision_decided_by varchar(128) [note: "REVIEW-07: 최종 판단 행위자"]
  annual_fee_due_date date [note: "Per-quarter annual-fee due date snapshot"]
  department_id varchar(64) [note: "Assigned business department id"]
  department_name varchar(128) [note: "Department name snapshot"]
  created_at timestamp [not null, note: "BaseEntity @CreatedDate, LocalDateTime"]
  updated_at timestamp [not null, note: "BaseEntity @LastModifiedDate, LocalDateTime"]

  indexes {
    (patent_id, quarter_key) [unique]
    (patent_id, created_at)
    review_workflow_status
    department_id
    (department_id, review_workflow_status)
    (department_id, business_opinion_decision)
  }
}

Table ai_report_edit_logs {
  id varchar(64) [pk]
  patent_id varchar(32) [not null]
  quarter_key varchar(16)
  editor varchar(128)
  edited_at timestamptz [not null]
  action varchar(32) [not null, note: "EDIT | REVERT | REGENERATED_OVER_EDIT (append-only 감사 로그)"]
  overrides_json text [note: "해당 시점의 누적 오버라이드 전체"]
  base_report_id varchar(128)

  indexes {
    (patent_id, edited_at)
  }
}

Table valuation_criteria_configs {
  id varchar(64) [pk]
  version int [not null, unique, note: "최신 버전이 활성 설정 (append-only)"]
  config_json text [not null, note: "계약 C1 valuationConfig 형태(camelCase) 그대로 — agent 무변환 전달"]
  created_by varchar(128)
  created_at timestamptz [not null]
}

Table patent_ai_report_jobs {
  job_id varchar(128) [pk]
  patent_id varchar(32) [not null]
  status varchar(32) [not null, note: "PENDING | RUNNING | SUCCEEDED | DEGRADED | FAILED"]
  requested_at timestamptz
  started_at timestamptz
  finished_at timestamptz
  message text
  report_id varchar(128)
}

Table quarter_settings {
  quarter_key varchar(12) [pk, note: "e.g. 2026-Q2"]
  setting_year int [not null, note: "Java field: year; @Column(name = \"setting_year\")"]
  quarter_number int [not null, note: "1-4"]
  start_date date
  end_date date
  activated boolean [not null, note: "Quarter review activation state"]
  activated_at timestamptz
  ended boolean [not null, note: "Set by QuarterActivationScheduler after end_date"]
  ended_at timestamptz
  submission_deadline date [note: "Business response deadline"]
  mail_lead_months_snapshot int [note: "Snapshot of review.mail.lead_months at activation time"]
}

Table review_period_templates {
  period_number int [pk, note: "1-based quarter number: 1-4"]
  start_month int [not null]
  start_day int [not null]
  end_month int [not null]
  end_day int [not null]

  note: "Year-independent quarter boundary template. SettingsService can generate quarter_settings for arbitrary years from this table."
}

Table mailing_history {
  mailing_id varchar(64) [pk, note: "Mailing batch/send id"]
  body text [note: "HTML mail body"]
  cc_emails_json text [note: "JSON text: [email]"]
  patent_count int [not null]
  patents_json text [note: "JSON text: [{patentId, managementNumber, title}]"]
  recipient_email varchar(256)
  recipient_name varchar(128)
  department_id varchar(64)
  sent_at timestamptz
  sent_by varchar(128)
  status varchar(32) [note: "SENT | FAILED | PENDING"]
  subject varchar(500)
}

Table departments {
  department_id varchar(64) [pk, note: "Business department master id, e.g. DEPT-ICT"]
  department_name varchar(128)
  updated_at date

  note: "Recipient users are derived from users.department_id; recipient email/name are not stored here."
}

Table users {
  id varchar(64) [pk, note: "USER-{UUID12}"]
  email varchar(256) [not null, unique, note: "Login id; email format validated at API layer"]
  password varchar(256) [not null, note: "BCrypt hash"]
  role varchar(32) [not null, note: "ADMIN | BUSINESS"]
  department_id varchar(64) [note: "Null for ADMIN; DEPT-* for BUSINESS"]
  username varchar(128) [note: "Display/person name"]
  created_at timestamptz [note: "Set in constructor using Asia/Seoul OffsetDateTime"]
}

Table auth_sessions {
  session_id varchar(64) [pk]
  user_id varchar(64) [not null]
  email varchar(256) [not null, note: "Login email snapshot"]
  refresh_token_hash varchar(128) [not null, unique, note: "SHA-256 hash of refresh token"]
  created_at timestamptz [not null]
  expires_at timestamptz [not null]
  last_used_at timestamptz
  revoked_at timestamptz
}

Table annual_fee_adjustments {
  adjustment_id varchar(64) [pk]
  patent_id varchar(32) [not null]
  previous_due_date date
  adjusted_due_date date [not null]
  reason varchar(1000)
  adjusted_by varchar(128)
  adjusted_at timestamptz [note: "Set in constructor using Asia/Seoul OffsetDateTime"]
}

Table system_settings {
  setting_key varchar(128) [pk]
  setting_value text
  updated_at timestamptz

  note: '''
  String key-value settings.

  Known key patterns:
    mail.gmail.username
    mail.gmail.app_password
    mail.gmail.oauth2.client_id
    mail.gmail.oauth2.client_secret
    mail.gmail.oauth2.refresh_token
    mail.gmail.oauth2.connected_email
    review.mail.lead_months                 default 2, allowed 0-24
    review.response.deadline.months         default 1, allowed 0-12
    review.response.deadline.days           default 0
    country.extension.KR                    default 12
    country.extension.JP                    default 12
    country.extension.CN                    default 12
    country.extension.US                    default 12
    country.extension.TW                    default 12
    classification.business                 newline-separated values
    classification.technology               newline-separated values
  '''
}

Table industry_report_chunks {
  chunk_id text [pk]
  text text [not null]
  metadata jsonb [not null, default: `'{}'::jsonb`, note: "JSONB metadata, e.g. source_name, industry, page, heading"]
  embedding_model text [not null]
  embedding vector [not null, note: "pgvector column: vector(dimensions), dimensions supplied by Agent runtime"]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    embedding [name: "industry_report_chunks_embedding_hnsw_idx", type: hnsw, note: "Actual DDL: USING hnsw (embedding vector_cosine_ops)"]
    (`metadata->>'industry'`) [name: "industry_report_chunks_industry_idx", note: "Actual DDL expression index"]
  }
}

Ref: patent_review_history.patent_id > patents.patent_id
Ref: patent_review_history.quarter_key > quarter_settings.quarter_key
Ref: patent_review_history.department_id > departments.department_id
Ref: mailing_history.department_id > departments.department_id
Ref: users.department_id > departments.department_id
Ref: auth_sessions.user_id > users.id
Ref: annual_fee_adjustments.patent_id > patents.patent_id

Table notifications {
  notification_id varchar(64) [pk]
  title varchar(200) [not null]
  message text [not null, note: "특허 제목이 삽입되어 길어질 수 있음 — varchar(1000) 오버플로 결함 수정"]
  target_role varchar(32) [not null, note: "ADMIN | BUSINESS"]
  link varchar(500)
  created_at timestamp [not null]
  updated_at timestamp [not null]
}

Table notification_read_states {
  id varchar(160) [pk, note: "{notification_id}|{user_id}"]
  notification_id varchar(64) [not null]
  user_id varchar(64) [not null]
}
