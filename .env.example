# PatentFlow Backend local environment

PATENTFLOW_JWT_SECRET=change-this-secret-for-local-development
PATENTFLOW_JWT_EXPIRATION_SECONDS=3600

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/patentflow
SPRING_DATASOURCE_USERNAME=patentflow
SPRING_DATASOURCE_PASSWORD=patentflow

PATENTFLOW_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
PATENTFLOW_AGENT_URL=http://localhost:8000

# MinIO (S3 호환) 설정
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=admin
S3_SECRET_KEY=password123
S3_BUCKET_NAME=patentflow-bucket # MinIO 웹 UI에서 만들 버킷 이름

AWS_REGION=ap-northeast-2
SPRING_CLOUD_AWS_REGION_STATIC=ap-northeast-2