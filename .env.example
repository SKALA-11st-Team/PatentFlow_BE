# PatentFlow Backend local environment

PATENTFLOW_JWT_SECRET=change-this-secret-for-local-development
PATENTFLOW_JWT_EXPIRATION_SECONDS=3600
PATENTFLOW_REFRESH_TOKEN_EXPIRATION_SECONDS=1209600

PATENTFLOW_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
PATENTFLOW_BOOTSTRAP_ADMIN_PASSWORD=change-this-initial-admin-password
PATENTFLOW_BOOTSTRAP_ADMIN_DISPLAY_NAME=특허관리자

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/patentflow?currentSchema=patentflow
SPRING_DATASOURCE_USERNAME=patentflow
SPRING_DATASOURCE_PASSWORD=patentflow
PATENTFLOW_DB_SCHEMA=patentflow

PATENTFLOW_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
PATENTFLOW_AGENT_URL=http://localhost:8000
PATENTFLOW_AI_REPORT_STORAGE_DIR=storage/ai-reports

# Google OAuth2 (Gmail 연동)
# Google Cloud Console → API 및 서비스 → 사용자 인증 정보 → OAuth 2.0 클라이언트 ID에서 발급
# 승인된 리디렉션 URI에 GOOGLE_OAUTH2_REDIRECT_URI 값을 등록해야 함
GOOGLE_OAUTH2_CLIENT_ID=
GOOGLE_OAUTH2_CLIENT_SECRET=
GOOGLE_OAUTH2_REDIRECT_URI=http://localhost:8080/api/v1/settings/mail/oauth2/google/callback
GOOGLE_OAUTH2_FRONTEND_URI=http://localhost:5173/admin/settings
